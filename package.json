{
  "name": "sc-ore-overlay",
  "private": true,
  "version": "1.0.0-rc.2",
  "description": "Non-obstructive desktop overlay that identifies Star Citizen ship-mining ores from the scanner Radar Signature (RS) reading.",
  "license": "MIT",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "setup:models": "node scripts/copy-models.mjs",
    "predev": "npm run setup:models && node scripts/ensure-electron.mjs",
    "prebuild": "npm run setup:models",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.node.json",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "ci": "biome ci .",
    "test": "vitest run",
    "test:watch": "vitest",
    "crawl": "tsx scripts/crawl-wiki.ts",
    "icon": "node scripts/make-icon.mjs",
    "dist": "npm run build && electron-builder"
  },
  "dependencies": {
    "@gutenye/ocr-browser": "^1.4.8",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.17.0",
    "onnxruntime-node": "^1.26.0",
    "onnxruntime-web": "^1.17.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sharp": "^0.33.5",
    "tailwind-merge": "^3.6.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@gutenye/ocr-node": "^1.4.8",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^33.3.1",
    "electron-builder": "^25.1.8",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^5.4.11",
    "vite-plugin-electron": "^0.29.0",
    "vitest": "^2.1.8"
  },
  "build": {
    "appId": "com.scoreoverlay.app",
    "productName": "SC Ore Overlay",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "!**/node_modules/onnxruntime-node/bin/napi-v6/linux/**",
      "!**/node_modules/onnxruntime-node/bin/napi-v6/darwin/**",
      "!**/node_modules/onnxruntime-node/bin/napi-v6/win32/arm64/**",
      "!**/node_modules/onnxruntime-web/**"
    ],
    "asarUnpack": [
      "**/node_modules/onnxruntime-node/**",
      "**/node_modules/sharp/**",
      "**/node_modules/@img/**"
    ],
    "extraResources": [
      {
        "from": "public/models",
        "to": "models"
      },
      {
        "from": "build/icon.png",
        "to": "icon.png"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "nsis": {
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico"
    }
  },
  "engines": {
    "node": ">=20"
  }
}
