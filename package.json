{
  "name": "sc-ore-overlay",
  "private": true,
  "version": "0.1.0",
  "description": "Non-obstructive desktop overlay that identifies Star Citizen ship-mining ores from the scanner Radar Signature (RS) reading.",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "setup:models": "node scripts/copy-models.mjs",
    "predev": "npm run setup:models && node scripts/ensure-electron.mjs",
    "prebuild": "npm run setup:models",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.node.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "crawl": "tsx scripts/crawl-wiki.ts",
    "dist": "npm run build && electron-builder"
  },
  "dependencies": {
    "@gutenye/ocr-browser": "^1.4.8",
    "onnxruntime-web": "^1.17.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^33.3.1",
    "electron-builder": "^25.1.8",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^5.4.11",
    "vite-plugin-electron": "^0.29.0",
    "vitest": "^2.1.8"
  },
  "build": {
    "appId": "com.scoreoverlay.app",
    "productName": "SC Ore Overlay",
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "win": {
      "target": "nsis"
    }
  },
  "engines": {
    "node": ">=20"
  }
}
