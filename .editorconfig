# Editor defaults for editors that don't run Biome. Kept in sync with biome.json
# (the formatter is the source of truth for TS/TSX/JSON).
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2
max_line_length = 100

[*.md]
trim_trailing_whitespace = false
